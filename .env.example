# Copy to .env before running Docker Compose. Replace every change-me value.
MYSQL_PASSWORD=change-me-mysql
MYSQL_ROOT_PASSWORD=change-me-root
DEMO_CONTROL_TOKEN=change-me-control
DEMO_PORT=8080

# Optional: connect the application containers to a DataKit reachable from Docker.
DATAKIT_HOST=host.docker.internal
DD_ENV=demo
DD_VERSION=local
PROJECT_TAG=mall-demo

# RUM is intentionally off until an application is created in TrueWatch.
RUM_ENABLED=false
RUM_APPLICATION_ID=
# Optional Trace deep link. A workspace ID is required before the UI emits links.
OBSERVABILITY_CONSOLE_URL=https://ap1-console.truewatch.com
OBSERVABILITY_WORKSPACE_ID=
