# Copy to .env before running Docker Compose. Replace every change-me value.
MYSQL_PASSWORD=change-me-mysql
MYSQL_ROOT_PASSWORD=change-me-root
DEMO_CONTROL_TOKEN=change-me-control
DEMO_PORT=8080

# Optional: connect the application containers to a DataKit reachable from Docker.
DATAKIT_HOST=host.docker.internal
DD_ENV=demo
DD_VERSION=local
PROJECT_TAG=mall-demo

# RUM is intentionally off until an application is created in Guance.
RUM_ENABLED=false
RUM_APPLICATION_ID=
GUANCE_CONSOLE_URL=https://console.guance.com
GUANCE_WORKSPACE_ID=
